rules_version = '2';



service cloud.firestore {

  match /databases/{database}/documents {

    function isSignedIn() {

      return request.auth != null;

    }



    function isOwner(userId) {

      return isSignedIn() && request.auth.uid == userId;

    }



    function isAdmin() {

      return isSignedIn() && request.auth.token.admin == true;

    }



    function isPublishedBook(bookId) {

      return get(/databases/$(database)/documents/books/$(bookId)).data.isPublished == true;

    }



    function isAlbumBookOwner(bookId) {
      return exists(/databases/$(database)/documents/books/$(bookId))
        && get(/databases/$(database)/documents/books/$(bookId)).data.userId == request.auth.uid;
    }

    function canAccessBookId(bookId) {
      return isAlbumBookOwner(bookId)
        || (exists(/databases/$(database)/documents/collabBooks/$(bookId))
          && isCollabBookMember(bookId));
    }

    function isLinkedAlbumBook(data) {
      return data.collabBookId != null
        && exists(/databases/$(database)/documents/collabBooks/$(data.collabBookId))
        && isCollabBookMember(data.collabBookId);
    }



    function canAccessAlbumBook(albumBookId) {
      return exists(/databases/$(database)/documents/books/$(albumBookId))
        && (
          get(/databases/$(database)/documents/books/$(albumBookId)).data.userId == request.auth.uid
          || isLinkedAlbumBook(get(/databases/$(database)/documents/books/$(albumBookId)).data)
        );
    }

    function isBookOwner(bookId) {
      return isAlbumBookOwner(bookId);
    }



    function isPublishedStory(storySessionId) {

      let story = get(/databases/$(database)/documents/storySessions/$(storySessionId));

      return (story.data.bookId != null && isPublishedBook(story.data.bookId))

        || (story.data.collabBookId != null
          && exists(/databases/$(database)/documents/collabBooks/$(story.data.collabBookId))
          && collabBookDoc(story.data.collabBookId).data.publishedAlbumBookId != null
          && isPublishedBook(collabBookDoc(story.data.collabBookId).data.publishedAlbumBookId))

        || (story.data.chapterId != null

          && exists(/databases/$(database)/documents/chapters/$(story.data.chapterId))

          && isPublishedBook(

            get(/databases/$(database)/documents/chapters/$(story.data.chapterId)).data.bookId

          ));

    }



    function storySessionData(storySessionId) {

      return get(/databases/$(database)/documents/storySessions/$(storySessionId)).data;

    }



    function canReadClip(clipData) {

      let story = storySessionData(clipData.storySessionId);

      return isPublishedStory(clipData.storySessionId)

        || isBrowsableStory(clipData.storySessionId)

        || isOwner(clipData.userId)

        || (story.bookOwnerId != null && isOwner(story.bookOwnerId))

        || (story.bookId != null && canAccessBookId(story.bookId))

        || isAdmin();

    }



    function isValidContributorCreate() {

      let invite = get(/databases/$(database)/documents/contributorInvites/$(request.resource.data.contributorInviteId));

      return request.resource.data.isContributorStory == true

        && invite.data.isActive == true

        && invite.data.bookId == request.resource.data.bookId

        && invite.data.ownerId == request.resource.data.bookOwnerId

        && request.resource.data.userId == request.auth.uid

        && request.resource.data.contributorName == invite.data.contributorName

        && request.resource.data.contributorRelationship == invite.data.relationship;

    }

    function contributorStoryLocked() {
      return resource.data.isContributorStory == true
        && resource.data.contributorSubmitted == true;
    }

    function contributorStoryLockedById(sessionId) {
      let s = get(/databases/$(database)/documents/storySessions/$(sessionId));
      return s.data.isContributorStory == true && s.data.contributorSubmitted == true;
    }

    function userEmail() {
      return isSignedIn() ? request.auth.token.email : null;
    }

    function isCollabBookMemberData(data) {
      return isSignedIn() && (
        data.ownerId == request.auth.uid ||
        request.auth.uid in data.collaborators
      );
    }

    function collabBookDoc(bookId) {
      return get(/databases/$(database)/documents/collabBooks/$(bookId));
    }

    function isCollabBookMember(bookId) {
      return isCollabBookMemberData(collabBookDoc(bookId).data);
    }

    function isCollabBookOwner(bookId) {
      return isSignedIn() && collabBookDoc(bookId).data.ownerId == request.auth.uid;
    }

    function hasActiveBrowseShare(collabBookId) {
      return exists(/databases/$(database)/documents/collabBooks/$(collabBookId))
        && collabBookDoc(collabBookId).data.activeShareToken != null
        && collabBookDoc(collabBookId).data.activeShareToken != '';
    }

    function collabBookIdForAlbum(albumBookId) {
      return get(/databases/$(database)/documents/books/$(albumBookId)).data.collabBookId;
    }

    function isBrowsableAlbumBook(albumBookId) {
      let collabId = collabBookIdForAlbum(albumBookId);
      return collabId != null && hasActiveBrowseShare(collabId);
    }

    function isBrowsableStory(sessionId) {
      let story = get(/databases/$(database)/documents/storySessions/$(sessionId)).data;
      return (story.bookId != null
          && exists(/databases/$(database)/documents/books/$(story.bookId))
          && isBrowsableAlbumBook(story.bookId))
        || (story.bookId != null && hasActiveBrowseShare(story.bookId))
        || (story.chapterId != null
          && exists(/databases/$(database)/documents/chapters/$(story.chapterId))
          && isBrowsableAlbumBook(
            get(/databases/$(database)/documents/chapters/$(story.chapterId)).data.bookId
          ));
    }



    match /users/{userId} {

      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId);

      allow update: if isOwner(userId) || isAdmin();

      allow delete: if isOwner(userId);

    }



    match /contributorInvites/{inviteId} {

      allow read: if resource.data.isActive == true

        || isOwner(resource.data.ownerId)

        || isBookOwner(resource.data.bookId)

        || isAdmin();

      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      allow update: if isOwner(resource.data.ownerId) || isAdmin();

      allow delete: if isOwner(resource.data.ownerId) || isAdmin();

    }



    match /books/{bookId} {

      allow read: if resource.data.isPublished == true

        || isBrowsableAlbumBook(bookId)

        || isOwner(resource.data.userId)

        || isLinkedAlbumBook(resource.data)

        || isAdmin();

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid

        && (request.resource.data.collabBookId == null

          || isCollabBookMember(request.resource.data.collabBookId));

      allow update: if isOwner(resource.data.userId)

        || isLinkedAlbumBook(resource.data)

        || isAdmin();

      allow delete: if isOwner(resource.data.userId) || isAdmin();

      match /private/{docId} {
        allow read, write: if canAccessAlbumBook(bookId) || isAdmin();
      }

    }



    match /chapters/{chapterId} {

      allow read: if isPublishedBook(resource.data.bookId)

        || isBrowsableAlbumBook(resource.data.bookId)

        || isOwner(resource.data.userId)

        || canAccessAlbumBook(resource.data.bookId)

        || isAdmin();

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      allow update: if isOwner(resource.data.userId) || canAccessAlbumBook(resource.data.bookId) || isAdmin();

      allow delete: if isOwner(resource.data.userId) || canAccessAlbumBook(resource.data.bookId) || isAdmin();

    }



    match /storySessions/{sessionId} {

      allow read: if isPublishedStory(sessionId)

        || isBrowsableStory(sessionId)

        || isOwner(resource.data.userId)

        || (resource.data.bookId != null && canAccessBookId(resource.data.bookId))

        || (resource.data.bookOwnerId != null && isOwner(resource.data.bookOwnerId))

        || isAdmin();

      allow create: if isSignedIn() && (

        (request.resource.data.userId == request.auth.uid && request.resource.data.isContributorStory != true)

        || isValidContributorCreate()

      );

      allow update: if (isOwner(resource.data.userId) && !contributorStoryLocked())

        || (resource.data.bookId != null && canAccessBookId(resource.data.bookId))

        || (resource.data.bookOwnerId != null && isOwner(resource.data.bookOwnerId))

        || (request.resource.data.bookOwnerId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['bookOwnerId', 'bookId', 'collabBookId', 'updatedAt']))

        || isAdmin();

      allow delete: if isOwner(resource.data.userId)

        || (resource.data.bookId != null && canAccessBookId(resource.data.bookId))

        || (resource.data.bookOwnerId != null && isOwner(resource.data.bookOwnerId))

        || isAdmin();

    }



    match /clips/{clipId} {

      allow read: if canReadClip(resource.data);

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      allow update: if (isOwner(resource.data.userId) && !contributorStoryLockedById(resource.data.storySessionId))

        || isAdmin();

      allow delete: if isOwner(resource.data.userId) || isAdmin();

    }



    match /stories/{storyId} {

      allow read: if isSignedIn() && (

        resource.data.userId == request.auth.uid ||

        resource.data.buyerId == request.auth.uid ||

        isAdmin()

      );

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() && (

        resource.data.userId == request.auth.uid ||

        resource.data.buyerId == request.auth.uid ||

        isAdmin()

      );

      allow delete: if isSignedIn() && (

        resource.data.userId == request.auth.uid || isAdmin()

      );

    }



    match /recordings/{recordingId} {

      allow read: if isSignedIn() && (

        resource.data.userId == request.auth.uid ||

        resource.data.buyerId == request.auth.uid ||

        isAdmin()

      );

      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() && (

        resource.data.userId == request.auth.uid ||

        resource.data.buyerId == request.auth.uid ||

        isAdmin()

      );

      allow delete: if isSignedIn() && (

        resource.data.userId == request.auth.uid || isAdmin()

      );

    }

    match /collabBooks/{bookId} {
      allow read: if isCollabBookMemberData(resource.data) || isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.collaborators is list;
      allow update: if isCollabBookOwner(bookId) || isAdmin();
      allow delete: if isCollabBookOwner(bookId) || isAdmin();

      match /prompts/{promptId} {
        allow read: if isCollabBookMember(bookId) || isAdmin();
        allow create: if isCollabBookMember(bookId)
          && request.resource.data.bookId == bookId
          && request.resource.data.createdBy == request.auth.uid;
        allow update: if isCollabBookOwner(bookId) || isAdmin();
        allow delete: if isCollabBookOwner(bookId)
          || (isCollabBookMember(bookId)
            && resource.data.source == 'user'
            && resource.data.createdBy == request.auth.uid)
          || isAdmin();
      }

      match /promptProgress/{progressUserId} {
        allow read: if isCollabBookMember(bookId) || isAdmin();
        allow create, update: if isCollabBookMember(bookId)
          && progressUserId == request.auth.uid;
        allow delete: if progressUserId == request.auth.uid || isAdmin();
      }

      match /photos/{photoId} {
        allow read: if isCollabBookMember(bookId) || isAdmin();
        allow create: if isCollabBookMember(bookId)
          && request.resource.data.bookId == bookId
          && request.resource.data.createdBy == request.auth.uid;
        allow update: if isCollabBookMember(bookId) || isAdmin();
        allow delete: if isCollabBookMember(bookId) || isAdmin();
      }
    }

    match /bookStories/{storyId} {
      allow read: if isCollabBookMember(resource.data.bookId) || isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && isCollabBookMember(request.resource.data.bookId);
      allow update: if isCollabBookMember(resource.data.bookId) || isAdmin();
      allow delete: if isCollabBookMember(resource.data.bookId) || isAdmin();
    }

    match /bookAudioClips/{clipId} {
      allow read: if isCollabBookMember(resource.data.bookId) || isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && isCollabBookMember(request.resource.data.bookId);
      allow update: if isCollabBookMember(resource.data.bookId) || isAdmin();
      allow delete: if isCollabBookMember(resource.data.bookId) || isAdmin();
    }

    match /bookInvitations/{token} {
      allow read: if true;
      allow create: if isSignedIn()
        && isCollabBookOwner(request.resource.data.bookId);
      allow update: if isSignedIn() && (
        isCollabBookOwner(resource.data.bookId) ||
        (
          resource.data.status == 'pending' &&
          request.resource.data.status == 'accepted' &&
          request.resource.data.inviteeUid == request.auth.uid &&
          (
            resource.data.inviteeEmail == userEmail() ||
            resource.data.inviteeUid == request.auth.uid
          )
        )
      );
      allow delete: if isCollabBookOwner(resource.data.bookId) || isAdmin();
    }

    match /publicBooks/{token} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && isCollabBookOwner(request.resource.data.bookId);
      allow delete: if isSignedIn() && isCollabBookOwner(resource.data.bookId);
    }

  }

}


