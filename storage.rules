rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidAudio() {
      return request.resource.contentType.matches('audio/.*')
        || request.resource.contentType == 'video/webm'
        || request.resource.contentType == 'application/octet-stream';
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
        || request.resource.contentType == 'application/octet-stream';
    }

    function isValidPdf() {
      return request.resource.contentType == 'application/pdf';
    }

    function albumBook(bookId) {
      return firestore.get(/databases/(default)/documents/books/$(bookId));
    }

    function isAlbumBookOwner(bookId) {
      return isSignedIn()
        && albumBook(bookId).data != null
        && albumBook(bookId).data.userId == request.auth.uid;
    }

    function isPublishedAlbumBook(bookId) {
      return albumBook(bookId).data != null
        && albumBook(bookId).data.isPublished == true;
    }

    function collabBook(bookId) {
      return firestore.get(/databases/(default)/documents/collabBooks/$(bookId));
    }

    function isCollabBookMember(bookId) {
      return isSignedIn()
        && collabBook(bookId).data != null
        && (
          collabBook(bookId).data.ownerId == request.auth.uid
          || (collabBook(bookId).data.collaborators != null
            && request.auth.uid in collabBook(bookId).data.collaborators)
        );
    }

    function isLinkedAlbumBook(bookId) {
      return albumBook(bookId).data != null
        && albumBook(bookId).data.collabBookId != null
        && isCollabBookMember(albumBook(bookId).data.collabBookId);
    }

    function canAccessAlbumBook(bookId) {
      return isAlbumBookOwner(bookId) || isLinkedAlbumBook(bookId);
    }

    function bookPhotoCollabId(sessionId) {
      return sessionId.split('book-photos-')[1];
    }

    function canReadBookPhotoSession(sessionId) {
      return sessionId.matches('book-photos-.*')
        && isCollabBookMember(bookPhotoCollabId(sessionId));
    }

    function storySessionDoc(sessionId) {
      return firestore.get(/databases/(default)/documents/storySessions/$(sessionId));
    }

    function canReadStorySession(sessionId) {
      let story = storySessionDoc(sessionId);
      return story.data != null && (
        (story.data.collabBookId != null && isCollabBookMember(story.data.collabBookId))
        || (story.data.bookId != null
          && firestore.exists(/databases/(default)/documents/collabBooks/$(story.data.bookId))
          && isCollabBookMember(story.data.bookId))
        || (story.data.bookId != null
          && firestore.exists(/databases/(default)/documents/books/$(story.data.bookId))
          && isAlbumBookOwner(story.data.bookId))
        || (story.data.bookId != null
          && firestore.exists(/databases/(default)/documents/books/$(story.data.bookId))
          && albumBook(story.data.bookId).data.collabBookId != null
          && isCollabBookMember(albumBook(story.data.bookId).data.collabBookId))
        || (story.data.chapterId != null
          && firestore.exists(/databases/(default)/documents/chapters/$(story.data.chapterId))
          && canAccessAlbumBook(
            firestore.get(/databases/(default)/documents/chapters/$(story.data.chapterId)).data.bookId
          ))
      );
    }

    // Legacy single-recording path
    match /recordings/{userId}/{recordingId}/{fileName} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 100 * 1024 * 1024
        && isValidAudio();
    }

    // Story session clips and images
    function isPublishedStorySession(sessionId) {
      let story = storySessionDoc(sessionId);
      return story.data != null && (
        (story.data.bookId != null
          && firestore.get(/databases/(default)/documents/books/$(story.data.bookId)).data.isPublished == true)
        || (story.data.collabBookId != null
          && firestore.exists(/databases/(default)/documents/collabBooks/$(story.data.collabBookId))
          && firestore.get(/databases/(default)/documents/collabBooks/$(story.data.collabBookId)).data.publishedAlbumBookId != null
          && firestore.get(
            /databases/(default)/documents/books/$(
              firestore.get(/databases/(default)/documents/collabBooks/$(story.data.collabBookId)).data.publishedAlbumBookId
            )
          ).data.isPublished == true)
        || (story.data.chapterId != null
          && firestore.exists(/databases/(default)/documents/chapters/$(story.data.chapterId))
          && firestore.get(
            /databases/(default)/documents/books/$(
              firestore.get(/databases/(default)/documents/chapters/$(story.data.chapterId)).data.bookId
            )
          ).data.isPublished == true)
      );
    }

    match /stories/{userId}/{sessionId}/clips/{clipId}/{fileName} {
      allow read: if (isSignedIn() && request.auth.uid == userId)
        || isPublishedStorySession(sessionId)
        || canReadStorySession(sessionId);
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 50 * 1024 * 1024
        && isValidAudio();
    }

    match /stories/{userId}/{sessionId}/images/{fileName} {
      allow read: if (isSignedIn() && request.auth.uid == userId)
        || isPublishedStorySession(sessionId)
        || canReadStorySession(sessionId)
        || canReadBookPhotoSession(sessionId);
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024
        && isValidImage();
    }

    match /stories/{userId}/{sessionId}/attachments/{fileName} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 50 * 1024 * 1024
        && (isValidImage() || request.resource.contentType.matches('video/.*'));
    }

    match /book-audio/{bookId}/{clipId}/{fileName} {
      allow read: if isCollabBookMember(bookId);
      allow write: if isCollabBookMember(bookId)
        && request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
    }

    match /collabBooks/{bookId}/photos/{photoId}/{fileName} {
      allow read: if isCollabBookMember(bookId);
      allow write: if isCollabBookMember(bookId)
        && request.resource.size < 20 * 1024 * 1024
        && isValidImage();
    }

    match /album-books/{bookId}/{fileName} {
      allow read: if isPublishedAlbumBook(bookId) || canAccessAlbumBook(bookId);
      allow write: if canAccessAlbumBook(bookId)
        && request.resource.size < 100 * 1024 * 1024
        && isValidPdf();
    }
  }
}
